  "role_permissions": {
    "parent": {
      "children": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "own"
      },
      "events": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "own_and_related"
      },
      "documents": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "own_and_related"
      },
      "planning": {
        "view_modes": "all",
        "export": true,
        "share": true
      }
    },
    "nanny": {
      "children": {
        "create": false,
        "read": true,
        "update": false,
        "delete": false,
        "scope": "assigned"
      },
      "events": {
        "create": true,
        "read": true,
        "update": "own_slots_only",
        "delete": "own_slots_only",
        "scope": "assigned_children"
      },
      "documents": {
        "create": false,
        "read": true,
        "update": false,
        "delete": false,
        "scope": "assigned_children"
      },
      "planning": {
        "view_modes": ["day", "week"],
        "export": false,
        "share": false
      }
    },
    "admin": {
      "children": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "all"
      },
      "events": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "all"
      },
      "documents": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "scope": "all"
      },
      "planning": {
        "view_modes": "all",
        "export": true,
        "share": true
      }
    }
  },
  "upgrade_prompts": {
    "children_limit_reached": {
      "fr": {
        "title": "Limite d'enfants atteinte",
        "message": "Vous avez atteint la limite de {current_limit} enfant(s) pour votre plan {current_plan}. Passez au plan {suggested_plan} pour ajouter plus d'enfants.",
        "cta": "Voir les plans"
      },
      "en": {
        "title": "Children limit reached",
        "message": "You have reached the limit of {current_limit} child(ren) for your {current_plan} plan. Upgrade to {suggested_plan} to add more children.",
        "cta": "View plans"
      }
    },
    "documents_limit_reached": {
      "fr": {
        "title": "Limite de documents atteinte",
        "message": "Vous avez atteint la limite de {current_limit} documents pour votre plan {current_plan}. Passez au plan {suggested_plan} pour télécharger plus de documents.",
        "cta": "Voir les plans"
      },
      "en": {
        "title": "Documents limit reached",
        "message": "You have reached the limit of {current_limit} documents for your {current_plan} plan. Upgrade to {suggested_plan} to upload more documents.",
        "cta": "View plans"
      }
    },
    "events_limit_reached": {
      "fr": {
        "title": "Limite d'événements atteinte",
        "message": "Vous avez atteint la limite de {current_limit} événements par jour pour votre plan {current_plan}. Passez au plan {suggested_plan} pour créer plus d'événements.",
        "cta": "Voir les plans"
      },
      "en": {
        "title": "Events limit reached",
        "message": "You have reached the limit of {current_limit} events per day for your {current_plan} plan. Upgrade to {suggested_plan} to create more events.",
        "cta": "View plans"
      }
    },
    "storage_limit_reached": {
      "fr": {
        "title": "Limite de stockage atteinte",
        "message": "Vous avez atteint la limite de stockage de {current_limit}MB pour votre plan {current_plan}. Passez au plan {suggested_plan} pour plus d'espace.",
        "cta": "Voir les plans"
      },
      "en": {
        "title": "Storage limit reached",
        "message": "You have reached the storage limit of {current_limit}MB for your {current_plan} plan. Upgrade to {suggested_plan} for more space.",
        "cta": "View plans"
      }
    }
  },
  "enforcement_rules": {
    "hard_limits": [
      "children.max_count",
      "documents.max_count",
      "events.max_per_day",
      "storage.total_mb"
    ],
    "soft_limits": [
      "events.max_per_month"
    ],
    "grace_period_days": 3,
    "downgrade_behavior": {
      "children": "hide_excess",
      "documents": "read_only_excess",
      "events": "prevent_new_creation",
      "features": "disable_immediately"
    }
  }
}