{
  "events": [
    {
      "event": "signup",
      "description": "Utilisateur s'inscrit sur l'application",
      "properties": {
        "role": {
          "type": "string",
          "description": "Rôle choisi (parent|nanny)",
          "required": true
        },
        "plan": {
          "type": "string",
          "description": "Plan sélectionné (free|starter|full)",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "Langue choisie (fr|en)",
          "required": false
        },
        "source": {
          "type": "string",
          "description": "Source d'acquisition (organic|referral|ads)",
          "required": false
        }
      }
    },
    {
      "event": "select_plan",
      "description": "Utilisateur sélectionne un plan d'abonnement",
      "properties": {
        "plan": {
          "type": "string",
          "description": "Plan sélectionné (free|starter|full)",
          "required": true
        },
        "previous_plan": {
          "type": "string",
          "description": "Plan précédent si changement",
          "required": false
        },
        "from_onboarding": {
          "type": "boolean",
          "description": "Si la sélection vient de l'onboarding",
          "required": false
        }
      }
    },
    {
      "event": "add_child",
      "description": "Parent ajoute un enfant",
      "properties": {
        "count_children_total": {
          "type": "number",
          "description": "Nombre total d'enfants après ajout",
          "required": true
        },
        "has_photo": {
          "type": "boolean",
          "description": "Si une photo a été ajoutée",
          "required": false
        },
        "has_allergies": {
          "type": "boolean",
          "description": "Si des allergies ont été renseignées",
          "required": false
        }
      }
    },
    {
      "event": "create_event",
      "description": "Utilisateur crée un événement dans le planning",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type d'événement (activity|meal|nap|outing|vacation)",
          "required": true
        },
        "duration_minutes": {
          "type": "number",
          "description": "Durée de l'événement en minutes",
          "required": false
        },
        "has_notes": {
          "type": "boolean",
          "description": "Si des notes ont été ajoutées",
          "required": false
        },
        "is_recurring": {
          "type": "boolean",
          "description": "Si l'événement est récurrent",
          "required": false
        }
      }
    },
    {
      "event": "upload_document",
      "description": "Utilisateur télécharge un document",
      "properties": {
        "child_id": {
          "type": "string",
          "description": "ID de l'enfant concerné",
          "required": true
        },
        "file_type": {
          "type": "string",
          "description": "Type de fichier (pdf|image|doc)",
          "required": false
        },
        "file_size_kb": {
          "type": "number",
          "description": "Taille du fichier en KB",
          "required": false
        },
        "total_documents": {
          "type": "number",
          "description": "Nombre total de documents après upload",
          "required": false
        }
      }
    },
    {
      "event": "change_language",
      "description": "Utilisateur change la langue de l'interface",
      "properties": {
        "from": {
          "type": "string",
          "description": "Langue précédente (fr|en)",
          "required": false
        },
        "to": {
          "type": "string",
          "description": "Nouvelle langue (fr|en)",
          "required": true
        }
      }
    },
    {
      "event": "upgrade_plan",
      "description": "Utilisateur change de plan d'abonnement",
      "properties": {
        "from": {
          "type": "string",
          "description": "Plan précédent (free|starter|full)",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "Nouveau plan (free|starter|full)",
          "required": true
        },
        "payment_method": {
          "type": "string",
          "description": "Méthode de paiement utilisée",
          "required": false
        }
      }
    },
    {
      "event": "login",
      "description": "Utilisateur se connecte",
      "properties": {
        "method": {
          "type": "string",
          "description": "Méthode de connexion (email|google|apple)",
          "required": false
        },
        "device_type": {
          "type": "string",
          "description": "Type d'appareil (mobile|tablet|desktop)",
          "required": false
        }
      }
    },
    {
      "event": "logout",
      "description": "Utilisateur se déconnecte",
      "properties": {
        "session_duration_minutes": {
          "type": "number",
          "description": "Durée de la session en minutes",
          "required": false
        }
      }
    },
    {
      "event": "view_dashboard",
      "description": "Utilisateur consulte le tableau de bord",
      "properties": {
        "events_today": {
          "type": "number",
          "description": "Nombre d'événements du jour",
          "required": false
        },
        "children_count": {
          "type": "number",
          "description": "Nombre d'enfants",
          "required": false
        }
      }
    },
    {
      "event": "view_planning",
      "description": "Utilisateur consulte le planning",
      "properties": {
        "view_type": {
          "type": "string",
          "description": "Type de vue (day|week)",
          "required": true
        },
        "events_visible": {
          "type": "number",
          "description": "Nombre d'événements visibles",
          "required": false
        }
      }
    },
    {
      "event": "export_data",
      "description": "Utilisateur exporte des données",
      "properties": {
        "export_type": {
          "type": "string",
          "description": "Type d'export (planning|documents|all)",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "Format d'export (pdf|csv|excel)",
          "required": false
        },
        "date_range_days": {
          "type": "number",
          "description": "Nombre de jours exportés",
          "required": false
        }
      }
    },
    {
      "event": "limit_reached",
      "description": "Utilisateur atteint une limite de son plan",
      "properties": {
        "limit_type": {
          "type": "string",
          "description": "Type de limite (children|documents|events)",
          "required": true
        },
        "current_plan": {
          "type": "string",
          "description": "Plan actuel de l'utilisateur",
          "required": true
        },
        "action_taken": {
          "type": "string",
          "description": "Action prise (upgrade|dismiss|contact)",
          "required": false
        }
      }
    },
    {
      "event": "error_occurred",
      "description": "Une erreur s'est produite dans l'application",
      "properties": {
        "error_type": {
          "type": "string",
          "description": "Type d'erreur (network|validation|server)",
          "required": true
        },
        "error_code": {
          "type": "string",
          "description": "Code d'erreur spécifique",
          "required": false
        },
        "page": {
          "type": "string",
          "description": "Page où l'erreur s'est produite",
          "required": false
        }
      }
    }
  ],
  "user_properties": {
    "role": {
      "type": "string",
      "description": "Rôle de l'utilisateur (parent|nanny|admin)"
    },
    "plan": {
      "type": "string",
      "description": "Plan d'abonnement actuel"
    },
    "plan_status": {
      "type": "string",
      "description": "Statut du plan (active|past_due|canceled)"
    },
    "language": {
      "type": "string",
      "description": "Langue préférée de l'utilisateur"
    },
    "children_count": {
      "type": "number",
      "description": "Nombre d'enfants gérés"
    },
    "documents_count": {
      "type": "number",
      "description": "Nombre de documents stockés"
    },
    "signup_date": {
      "type": "datetime",
      "description": "Date d'inscription"
    },
    "last_active": {
      "type": "datetime",
      "description": "Dernière activité"
    }
  },
  "funnels": [
    {
      "name": "Onboarding Funnel",
      "steps": [
        "signup",
        "select_plan",
        "add_child",
        "create_event"
      ]
    },
    {
      "name": "Upgrade Funnel",
      "steps": [
        "limit_reached",
        "view_pricing",
        "select_plan",
        "upgrade_plan"
      ]
    }
  ],
  "cohorts": [
    {
      "name": "New Users",
      "definition": "Users who signed up in the last 7 days"
    },
    {
      "name": "Active Parents",
      "definition": "Users with role=parent who created an event in the last 30 days"
    },
    {
      "name": "Paid Users",
      "definition": "Users with plan=starter or plan=full"
    },
    {
      "name": "Power Users",
      "definition": "Users who have >5 children or >20 documents"
    }
  ]
}