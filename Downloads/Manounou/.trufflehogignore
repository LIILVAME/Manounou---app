# TruffleHog Ignore File
# Fichier pour ignorer les faux positifs du scan de sécurité

# ============================================
# Dossiers entiers à ignorer
# ============================================

# Code Swift natif (iOS natif, pas Flutter)
# Ce dossier contient du code Swift avec des paramètres de fonction
# qui génèrent des faux positifs (password, key, token, etc.)
Manounou/

# Fichiers de test et validation
**/test/**
**/tests/**
**/ManounouTests/**
**/ManounouUITests/**
**/ValidationScripts/**
**/*test*.swift
**/*Test*.swift

# Fichiers de documentation
**/*.md
**/README*
**/docs/**

# Fichiers de configuration FlutterFlow
**/flutterflow_export/**

# Fichiers de build et cache
**/build/**
**/.dart_tool/**
**/.build/**
**/Pods/**

# ============================================
# Patterns spécifiques (faux positifs)
# ============================================

# Paramètres de fonction Swift (pas de vrais secrets)
# Ces patterns sont des signatures de fonction, pas des secrets hardcodés
password: String
email: String
apiKey: String
token: String
forKey key: String
forKey: String
CodingKeys
supabaseAnonKey
supabaseKey

# Patterns de configuration (faux positifs)
# Ces patterns sont des clés de configuration, pas des secrets
CFBundle*
LSRequires*
UIRequired*
UISupported*
NSCameraUsage*
NSPhotoLibrary*

# Patterns de cache et storage (faux positifs)
# Ces patterns sont des noms de clés de cache, pas des secrets
cache\[key\]
kvStore\[key\]
lruKeys
removeValue\(forKey

