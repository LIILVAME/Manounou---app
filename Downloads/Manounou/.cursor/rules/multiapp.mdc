## 🔐 RÈGLES DE SÉCURITÉ (RLS & POLICIES)

```sql
alter table users enable row level security;
alter table children enable row level security;
alter table events enable row level security;
alter table documents enable row level security;

create policy "Users can access their own profile"
on users for all using (auth.uid() = id);

create policy "Parents can access their children"
on children for all using (auth.uid() = parent_id);

create policy "Parents can access their events"
on events for all using (
  auth.uid() in (select parent_id from children where id = events.child_id)
);

create policy "Parents can access their documents"
on documents for all using (
  auth.uid() in (select parent_id from children where id = documents.child_id)
);
```

