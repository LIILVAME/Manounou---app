# Configuration Manounou App
# Copiez ce fichier vers .env et configurez vos valeurs

# ================================
# CONFIGURATION GÉNÉRALE
# ================================
APP_ENV=development
APP_VERSION=1.0.0
APP_NAME=Manounou

# ================================
# EXPO CONFIGURATION
# ================================
EXPO_PROJECT_ID=your-expo-project-id
EXPO_PUBLIC_APP_VARIANT=development

# ================================
# APPLE CONFIGURATION
# ================================
APPLE_ID=your-apple-id@example.com
ASC_APP_ID=your-app-store-connect-app-id
APPLE_TEAM_ID=your-apple-team-id

# ================================
# GOOGLE CONFIGURATION
# ================================
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# ================================
# API ET BACKEND
# ================================
API_BASE_URL=https://api.manounou.app
API_TIMEOUT=10000
API_VERSION=v1

# ================================
# FIREBASE CONFIGURATION
# ================================
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=manounou-app.firebaseapp.com
FIREBASE_PROJECT_ID=manounou-app
FIREBASE_STORAGE_BUCKET=manounou-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ================================
# SUPABASE CONFIGURATION
# ================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ================================
# STRIPE CONFIGURATION
# ================================
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Plans d'abonnement Stripe
STRIPE_BASIC_PLAN_ID=price_basic_plan_id
STRIPE_PREMIUM_PLAN_ID=price_premium_plan_id
STRIPE_FAMILY_PLAN_ID=price_family_plan_id

# ================================
# NOTIFICATIONS PUSH
# ================================
EXPO_PUSH_TOKEN=your_expo_push_token
FCM_SERVER_KEY=your_fcm_server_key
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id

# ================================
# GÉOLOCALISATION
# ================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# ================================
# ANALYTICS ET MONITORING
# ================================
SENTRY_DSN=your_sentry_dsn
MIXPANEL_TOKEN=your_mixpanel_token
GOOGLE_ANALYTICS_ID=your_ga_id

# ================================
# STOCKAGE ET CDN
# ================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-3
AWS_S3_BUCKET=manounou-app-storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# ================================
# EMAIL ET COMMUNICATION
# ================================
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@manounou.app
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+33123456789

# ================================
# SÉCURITÉ
# ================================
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key
HASH_SALT_ROUNDS=12

# ================================
# DÉVELOPPEMENT
# ================================
DEBUG_MODE=true
LOG_LEVEL=debug
ENABLE_FLIPPER=true
ENABLE_REACTOTRON=true

# ================================
# EXPO CONFIGURATION
# ================================
EXPO_PROJECT_ID=your_expo_project_id
EAS_PROJECT_ID=your_eas_project_id

# ================================
# APP STORE CONFIGURATION
# ================================
IOS_BUNDLE_ID=com.manounou.app
ANDROID_PACKAGE=com.manounou.app
APP_STORE_ID=your_app_store_id
GOOGLE_PLAY_ID=com.manounou.app

# ================================
# URLS ET LIENS
# ================================
APP_WEBSITE=https://manounou.app
PRIVACY_POLICY_URL=https://manounou.app/privacy
TERMS_OF_SERVICE_URL=https://manounou.app/terms
SUPPORT_URL=https://manounou.app/support
SUPPORT_EMAIL=support@manounou.app

# ================================
# RÉSEAUX SOCIAUX
# ================================
FACEBOOK_APP_ID=your_facebook_app_id
GOOGLE_CLIENT_ID=your_google_client_id
APPLE_CLIENT_ID=your_apple_client_id

# ================================
# CONFIGURATION SPÉCIFIQUE ENVIRONNEMENT
# ================================

# Development
# API_BASE_URL=http://localhost:3000
# DEBUG_MODE=true
# LOG_LEVEL=debug

# Staging
# API_BASE_URL=https://staging-api.manounou.app
# DEBUG_MODE=false
# LOG_LEVEL=info

# Production
# API_BASE_URL=https://api.manounou.app
# DEBUG_MODE=false
# LOG_LEVEL=error

# ================================
# NOTES DE CONFIGURATION
# ================================
# 1. Ne jamais commiter le fichier .env en production
# 2. Utiliser des clés différentes pour dev/staging/prod
# 3. Rotationner régulièrement les clés sensibles
# 4. Utiliser des services de gestion de secrets en production
# 5. Valider toutes les variables d'environnement au démarrage